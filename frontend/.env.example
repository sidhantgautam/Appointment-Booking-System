# Voice AI Clinic Frontend Environment Variables

# Backend API URL (optional - defaults to http://localhost:8000)
REACT_APP_API_URL=http://localhost:8000

# Enable debug mode (optional)
REACT_APP_DEBUG=false

# App title (optional)
REACT_APP_TITLE="Voice AI Clinic"

# Performance monitoring (optional)
REACT_APP_ENABLE_PERFORMANCE_MONITORING=true

# Voice recording settings (optional)
REACT_APP_MAX_RECORDING_DURATION=60000
REACT_APP_AUDIO_SAMPLE_RATE=44100